{
  "name": "@spautz/limited-cache-demo--vite-react-app",
  "private": true,
  "description": "Basic UI demo app for the limited-cache package",
  "license": "MIT",
  "homepage": "https://github.com/spautz/limited-cache/blob/main/demos/vite-react-app#readme",
  "bugs": "https://github.com/spautz/limited-cache/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spautz/limited-cache.git",
    "directory": "demos/vite-react-app"
  },
  "author": {
    "name": "Steven Pautz",
    "url": "https://stevenpautz.com"
  },
  "source": "./src/main.tsx",
  "type": "module",
  "scripts": {
    "____ STANDARD PACKAGE TASKS ________________________________________": "",
    "all": "turbo run pipeline-all",
    "all:ci": "turbo run pipeline-ci --ui=stream",
    "build": "pnpm run build:clean && pnpm run build:main",
    "clean": "pnpm run \"/^.*:clean$/\" && rimraf --glob ./node_modules/.cache ./.turbo ./*.log",
    "dev": "vite",
    "lint": "biome check --write .",
    "lint:verify": "biome check .",
    "start": "vite preview",
    "test:clean": "rimraf ./coverage",
    "test": "pnpm run test:clean       && vitest run --coverage",
    "test:ci": "pnpm run test:clean    && vitest run --coverage --bail 1",
    "test:ui": "pnpm run test:clean    && vitest --ui",
    "test:watch": "pnpm run test:clean && vitest watch --coverage",
    "typecheck": "tsc -p ./tsconfig.json --noEmit",
    "____ BUILD & DEPLOY TASKS __________________________________________": "",
    "build:clean": "rimraf ./dist",
    "build:main": "vite build",
    "build:watch": "pnpm run build:clean && vite build --watch",
    "size-check": "source-map-explorer dist/**/*.js"
  },
  "dependencies": {
    "limited-cache": "workspace:^",
    "react": "catalog:demos",
    "react-dom": "catalog:demos"
  },
  "devDependencies": {
    "@skip-the-build/vite": "^1.1.1",
    "@testing-library/jest-dom": "catalog:shared",
    "@testing-library/react": "catalog:shared",
    "@types/react": "catalog:demos",
    "@types/react-dom": "catalog:demos",
    "@vitest/coverage-v8": "catalog:shared",
    "@vitest/ui": "catalog:shared",
    "typescript": "catalog:demos"
  }
}
